   overriding
   function Name (T : Test_Case) return AUnit.Message_String is
      pragma Unreferenced (T);
   begin
      return AUnit.Format ("Zlib.Seven_Zip stock LZMA interop");
   end Name;

   procedure Check (Label : String; Archive : Byte_Array) is
      Status : Status_Code;
      Result : constant Byte_Array :=
        Extract_Seven_Zip (Archive, "inp.bin", Status);
   begin
      Assert
        (Status = Ok,
         "extraction of stock 7z " & Label & " archive failed: "
         & Status_Image (Status));
      Assert
        (Result = LZMA_Input,
         "stock 7z " & Label & " payload mismatch");
   end Check;

   procedure Test_Stock_LZMA
     (T : in out AUnit.Test_Cases.Test_Case'Class)
   is
      pragma Unreferenced (T);
   begin
      Check ("LZMA", Stock_LZMA);
   end Test_Stock_LZMA;

   procedure Test_Stock_LZMA2
     (T : in out AUnit.Test_Cases.Test_Case'Class)
   is
      pragma Unreferenced (T);
   begin
      Check ("LZMA2", Stock_LZMA2);
   end Test_Stock_LZMA2;

   --  End-to-end: a real stock ARM->LZMA chain whose pack contains a branch
   --  pattern. The bind-pair packed-coder bug made this desync; verify the
   --  full 1800-byte payload extracts with the expected CRC-32.
   procedure Test_Stock_ARM_LZMA_Chain
     (T : in out AUnit.Test_Cases.Test_Case'Class)
   is
      pragma Unreferenced (T);
      Status : Zlib.Status_Code;
      Result : constant Byte_Array :=
        Extract_Seven_Zip (Stock_ARM_LZMA, "in_1800.bin", Status);
   begin
      Assert
        (Status = Ok,
         "stock 7z ARM+LZMA chain extraction failed: "
         & Status_Image (Status));
      Assert
        (Result'Length = 1800,
         "stock 7z ARM+LZMA chain wrong output length");
      Assert
        (Zlib.CRC32 (Result) = 16#1423_2611#,
         "stock 7z ARM+LZMA chain payload CRC mismatch");
   end Test_Stock_ARM_LZMA_Chain;

   overriding
   procedure Register_Tests (T : in out Test_Case) is
      use AUnit.Test_Cases;
   begin
      Registration.Register_Routine
        (T, Test_Stock_LZMA'Access, "stock 7z LZMA archive decode");
      Registration.Register_Routine
        (T, Test_Stock_LZMA2'Access, "stock 7z LZMA2 archive decode");
      Registration.Register_Routine
        (T, Test_Stock_ARM_LZMA_Chain'Access,
         "stock 7z ARM+LZMA filter chain decode");
   end Register_Tests;

end Zlib_Seven_Zip_LZMA_Interop_Tests;
